  "queries": [
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "2933ee44-ed11-49e1-87ae-d24e11afd3d4"
      },
      "text": "_Base | summarize maxHigh=max(High), minLow=min(Low), avgOpen=avg(Open), avgClose=avg(Close) by Ticker | render table",
      "id": "d5d0b92c-8f48-4eb0-b1e4-0afbb3cbe74a",
      "usedVariables": [
        "_Base",
        "_Date"
      ]
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "2933ee44-ed11-49e1-87ae-d24e11afd3d4"
      },
      "text": "_Base | summarize countVolume=count() by Ticker | top 10 by countVolume | render columnchart",
      "id": "62e96c91-4a85-462d-bd4a-80326d7ac98e",
      "usedVariables": [
        "_Base",
        "_Date"
      ]
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "2933ee44-ed11-49e1-87ae-d24e11afd3d4"
      },
      "text": "_Base | summarize avgPrice=avg(toreal(Open)) by Ticker | top 10 by avgPrice ",
      "id": "d4399cfe-d0ce-40c2-bec8-7d149583a533",
      "usedVariables": [
        "_Base"
      ]
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "2933ee44-ed11-49e1-87ae-d24e11afd3d4"
      },
      "text": "_Base\r\n| where Ticker has 'MSFT'\r\n| where Date > datetime_add('year', -10, now())\r\n| project Date, Close | render linechart\r\n",
      "id": "18313dee-bbc7-41c3-9635-85b2adf97183",
      "usedVariables": [
        "_Base"
      ]
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "2933ee44-ed11-49e1-87ae-d24e11afd3d4"
      },
      "text": "let TimeRange=toscalar(_Base | summarize Start=min(column_ifexists(_Date,ingestion_time())),End=max(column_ifexists(_Date,ingestion_time()))| project totimespan(End - Start));let Bin=case(TimeRange > 7d,1d,TimeRange> 1d,1h,TimeRange>6h,10m,1m);_Base| summarize Rows=count() by bin(column_ifexists(_Date,ingestion_time()),Bin)",
      "id": "1eed0159-19f0-4401-a6df-c6e81327623e",
      "usedVariables": [
        "_Base",
        "_Date"
      ]
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "2933ee44-ed11-49e1-87ae-d24e11afd3d4"
      },
      "text": "_schema| project ColumnName,ColumnType",
      "id": "dc9e2dc2-a830-4226-a952-6fee2fc9702e",
      "usedVariables": [
        "_schema"
      ]
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "2933ee44-ed11-49e1-87ae-d24e11afd3d4"
      },
      "text": "_Base| take 100",
      "id": "e8588059-cec1-4e5d-a4f6-a6e0e3c98c16",
      "usedVariables": [
        "_Base"
      ]
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "2933ee44-ed11-49e1-87ae-d24e11afd3d4"
      },
      "text": "_Base| summarize Lowest=min(column_ifexists(_Column,ingestion_time())),Highest=max(column_ifexists(_Column,ingestion_time()))",
      "id": "00b5aae1-99fc-43bb-b121-e8040103c178",
      "usedVariables": [
        "_Base",
        "_Column"
      ]
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "2933ee44-ed11-49e1-87ae-d24e11afd3d4"
      },
      "text": "_Base| summarize UniqueVales=dcount(column_ifexists(_Column,ingestion_time()))",
      "id": "d39d9a71-f6b7-4b59-b142-fac47e048986",
      "usedVariables": [
        "_Base",
        "_Column"
      ]
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "2933ee44-ed11-49e1-87ae-d24e11afd3d4"
      },
      "text": "_Base| take 1000000 | summarize ['Appears in 1M sample rows']=count() by  tostring(Ticker)| take 10| order by ['Appears in 1M sample rows']",
      "id": "d501e0ce-a3cf-41af-bca2-a7663846665e",
